# CTFd
CTFD_URL=https://ctf.example.com
CTFD_TOKEN=ctfd_your_api_token_here

# Platform: ctfd or htb. HTB MCP is attempted in auto mode when a token is set.
PLATFORM=htb
HTB_EVENT_ID=1434
HTB_TOKEN=paste_your_htb_bearer_token_here
HTB_COOKIE=
HTB_USER=
HTB_PASS=
HTB_MODE=auto
HTB_LOGIN_PATH=/auth/login
HTB_LOGIN_URL=https://account.hackthebox.com/api/v1/auth/login
HTB_CAPTCHA_TOKEN=
CHALLENGE_POLICY_FILE=challenge-policy.yml

# API Keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
